{% comment %}
  TRMNL "Half Vertical" layout (tall, narrow tile) for the shopping list.
  Paste into the Half Vertical tab of the plugin Markup editor.

  Tall but narrow tile — single column, overflow counter for hidden items.
  Merge vars: items[], count, updated_at
{% endcomment %}

<div class="layout">
  {% if count == 0 %}
    <div class="layout layout--center">
      <div class="flex flex--col gap--small">
        <span class="value value--large">All done</span>
        <span class="label">Shopping list is empty</span>
      </div>
    </div>
  {% else %}
    <div class="columns" data-overflow-max-cols="1" data-overflow-counter="true">
      <div class="column">
        {% for item in items %}
          <div class="item">
            <div class="meta"></div>
            <div class="content">
              <span class="title title--small">{{ item.name }}</span>
              {% if item.specification != "" %}
                <span class="description">{{ item.specification }}</span>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}
</div>

<div class="title_bar">
  <span class="title">Shopping</span>
  <span class="instance">{{ count }} item{% if count != 1 %}s{% endif %}</span>
</div>
