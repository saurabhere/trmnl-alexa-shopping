{% comment %}
  TRMNL "Quadrant" layout (smallest tile) for the shopping list.
  Paste into the Quadrant tab of the plugin Markup editor.

  Smallest tile — up to 2 columns with overflow counter.
  Merge vars: items[], count
{% endcomment %}

<div class="layout">
  {% if count == 0 %}
    <div class="layout layout--center">
      <div class="flex flex--col gap--small">
        <span class="value value--large">0</span>
        <span class="label">list empty</span>
      </div>
    </div>
  {% else %}
    <div class="columns" data-overflow-max-cols="2" data-overflow-counter="true">
      <div class="column">
        {% for item in items %}
          <div class="item">
            <div class="meta"></div>
            <div class="content">
              <span class="title title--small">{{ item.name }}</span>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}
</div>

<div class="title_bar">
  <span class="title">Shopping</span>
  <span class="instance">{{ count }}</span>
</div>
