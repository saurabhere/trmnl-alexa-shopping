{% comment %}
  TRMNL "Half Horizontal" layout (wide, short tile) for the shopping list.
  Paste into the Half Horizontal tab of the plugin Markup editor.

  Wide but short tile — allow up to 2 columns with overflow counter.
  Merge vars: items[], count, updated_at
{% endcomment %}

<div class="layout">
  {% if count == 0 %}
    <div class="layout layout--center">
      <div class="flex flex--col gap--small">
        <span class="value value--large">All done</span>
        <span class="label">Shopping list is empty</span>
      </div>
    </div>
  {% else %}
    <div class="columns" data-overflow-max-cols="2" data-overflow-counter="true">
      <div class="column">
        {% for item in items %}
          <div class="item">
            <div class="meta"></div>
            <div class="content">
              <span class="title title--small">{{ item.name }}</span>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}
</div>

<div class="title_bar">
  <span class="title">Shopping List</span>
  <span class="instance">{{ count }} item{% if count != 1 %}s{% endif %}</span>
</div>
