# Copy to .env and fill in. Never commit the real .env.
BRING_EMAIL=you@example.com
BRING_PASSWORD=your-bring-password
# Optional: which Bring list to read. Leave blank for your account default.
BRING_LIST_NAME=
# Bring locale (affects the API); US is fine for most.
BRING_COUNTRY=US

# From your TRMNL private plugin (Webhook strategy). The plugin UUID is the last
# path segment of the webhook URL: https://trmnl.com/api/custom_plugins/<UUID>
TRMNL_PLUGIN_UUID=
